# Copy to `.env.local` for local dev, or pass as a build arg in the container.
#
# Base URL of the url-shortener service. When set, "Copy share link" mints a
# short, stable link via the shortener (POST /, then PUT /{slug} to update it on
# later edits), falling back to the long self-contained link if the service is
# unreachable. Leave empty to disable the integration entirely.
VITE_SHORTENER_URL=
